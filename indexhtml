<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Avalanche Engineering — Water Treatment Solutions</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;500;600;700;800&family=Outfit:wght@300;400;500;600&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}

:root {
  --sky: #29ABE2;
  --sky-dark: #0D8EC0;
  --sky-light: #7DD3F0;
  --sky-pale: #E0F4FC;
  --sky-ultra: #F0FAFF;
  --navy: #0A1628;
  --navy-2: #0F1E35;
  --black: #0C0C0E;
  --white: #FFFFFF;
  --grey-1: #F5F8FA;
  --grey-2: #E8EFF4;
  --grey-3: #C2D0DA;
  --grey-4: #8A9BAA;
  --grey-5: #4A5A68;
  --text: #1A2530;
  --text-2: #4A5A68;
  --text-3: #8A9BAA;
  --font-display: 'Barlow Condensed', sans-serif;
  --font-body: 'Outfit', sans-serif;
  --font-text: 'Barlow', sans-serif;
  --nav-h: 76px;
  --max-w: 1220px;
  --radius: 2px;
}

html{scroll-behavior:smooth;}
body{background:var(--white);color:var(--text);font-family:var(--font-body);font-weight:400;line-height:1.65;overflow-x:hidden;}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-thumb{background:var(--sky);border-radius:4px;}

/* ── NAV ── */
nav{
  position:fixed;top:0;left:0;right:0;
  height:var(--nav-h);z-index:1000;
  display:flex;align-items:center;justify-content:space-between;
  padding:0 64px;
  background:rgba(255,255,255,0.97);
  border-bottom:2px solid var(--sky-pale);
  transition:box-shadow 0.3s;
}
nav.scrolled{box-shadow:0 4px 32px rgba(41,171,226,0.12);}
.nav-logo{display:flex;flex-direction:column;cursor:pointer;text-decoration:none;user-select:none;line-height:1;}
.nav-logo-main{font-family:var(--font-display);font-size:1.55rem;font-weight:800;letter-spacing:0.04em;text-transform:uppercase;color:var(--navy);}
.nav-logo-main span{color:var(--sky);}
.nav-logo-sub{font-family:var(--font-body);font-size:0.62rem;font-weight:500;letter-spacing:0.22em;text-transform:uppercase;color:var(--grey-4);margin-top:1px;}
.nav-links{display:flex;gap:36px;list-style:none;}
.nav-links a{font-family:var(--font-display);font-size:0.88rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--grey-5);text-decoration:none;cursor:pointer;transition:color 0.25s;position:relative;padding-bottom:3px;}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:2px;background:var(--sky);transition:width 0.25s;}
.nav-links a:hover,.nav-links a.active{color:var(--navy);}
.nav-links a:hover::after,.nav-links a.active::after{width:100%;}
.nav-cta{font-family:var(--font-display);font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--white);background:var(--sky);border:none;padding:11px 26px;cursor:pointer;transition:all 0.25s;border-radius:var(--radius);}
.nav-cta:hover{background:var(--sky-dark);transform:translateY(-1px);}
.menu-toggle{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:5px;background:none;border:none;}
.menu-toggle span{width:24px;height:2px;background:var(--navy);display:block;}

/* ── MOBILE NAV ── */
.mobile-nav{display:none;position:fixed;inset:0;background:var(--white);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:32px;}
.mobile-nav.open{display:flex;}
.mobile-nav a{font-family:var(--font-display);font-size:2.2rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--navy);text-decoration:none;cursor:pointer;transition:color 0.2s;}
.mobile-nav a:hover{color:var(--sky);}
.mobile-close{position:absolute;top:24px;right:28px;background:none;border:none;font-size:1.6rem;cursor:pointer;color:var(--grey-5);}

/* ── PAGES ── */
.page{display:none;min-height:100vh;}
.page.active{display:block;}
@keyframes pageIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}
.page-in{animation:pageIn 0.35s ease forwards;}

/* ── BUTTONS ── */
.btn-primary{font-family:var(--font-display);font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--white);background:var(--sky);border:none;padding:15px 36px;cursor:pointer;transition:all 0.25s;display:inline-block;text-decoration:none;border-radius:var(--radius);}
.btn-primary:hover{background:var(--sky-dark);transform:translateY(-2px);box-shadow:0 8px 24px rgba(41,171,226,0.3);}
.btn-outline{font-family:var(--font-display);font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--sky);background:transparent;border:2px solid var(--sky);padding:13px 34px;cursor:pointer;transition:all 0.25s;display:inline-block;border-radius:var(--radius);}
.btn-outline:hover{background:var(--sky);color:var(--white);}
.btn-white{font-family:var(--font-display);font-size:0.82rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--sky-dark);background:var(--white);border:none;padding:15px 36px;cursor:pointer;transition:all 0.25s;display:inline-block;border-radius:var(--radius);}
.btn-white:hover{background:var(--sky-pale);transform:translateY(-2px);}

/* ── SECTIONS ── */
.section{max-width:var(--max-w);margin:0 auto;padding:96px 64px;}
.section-label{font-family:var(--font-display);font-size:0.72rem;font-weight:700;letter-spacing:0.26em;text-transform:uppercase;color:var(--sky);margin-bottom:12px;display:flex;align-items:center;gap:10px;}
.section-label::before{content:'';width:28px;height:2px;background:var(--sky);}
.section-title{font-family:var(--font-display);font-size:clamp(2.2rem,3.8vw,3.4rem);font-weight:800;letter-spacing:0.02em;text-transform:uppercase;line-height:1.05;color:var(--navy);margin-bottom:16px;}
.section-title span{color:var(--sky);}
.section-sub{font-size:1rem;color:var(--text-2);max-width:520px;line-height:1.75;}

/* ── HERO ── */
.hero{
  min-height:100vh;
  background:var(--navy);
  position:relative;
  overflow:hidden;
  display:flex;align-items:center;
}
.hero-bg-pattern{
  position:absolute;inset:0;
  background-image:
    radial-gradient(circle at 70% 50%, rgba(41,171,226,0.12) 0%, transparent 55%),
    radial-gradient(circle at 10% 80%, rgba(41,171,226,0.07) 0%, transparent 45%);
}
.hero-lines{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(41,171,226,0.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(41,171,226,0.06) 1px, transparent 1px);
  background-size:60px 60px;
}
#hero-canvas{position:absolute;inset:0;opacity:0.6;}
.hero-diagonal{
  position:absolute;right:-10%;bottom:0;
  width:55%;height:100%;
  background:linear-gradient(135deg, transparent 50%, rgba(41,171,226,0.07) 50%);
}
.hero-content{
  position:relative;z-index:10;
  max-width:var(--max-w);margin:0 auto;
  padding:calc(var(--nav-h) + 80px) 64px 100px;
  width:100%;
}
.hero-badge{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(41,171,226,0.15);border:1px solid rgba(41,171,226,0.3);
  padding:7px 16px;margin-bottom:32px;
  font-family:var(--font-display);font-size:0.7rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;color:var(--sky-light);
  opacity:0;animation:fadeUp 0.7s ease 0.2s forwards;
}
.hero-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--sky-light);}
.hero-headline{
  font-family:var(--font-display);font-size:clamp(3.8rem,8vw,8rem);
  font-weight:800;letter-spacing:0.01em;text-transform:uppercase;
  line-height:0.95;color:var(--white);margin-bottom:30px;
  max-width:750px;
  opacity:0;animation:fadeUp 0.7s ease 0.4s forwards;
}
.hero-headline span{
  color:transparent;-webkit-text-stroke:2px var(--sky);
  display:block;
}
.hero-sub{
  font-size:1.05rem;font-weight:300;color:rgba(255,255,255,0.65);
  max-width:480px;line-height:1.78;margin-bottom:44px;
  opacity:0;animation:fadeUp 0.7s ease 0.6s forwards;
}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap;opacity:0;animation:fadeUp 0.7s ease 0.8s forwards;}
.hero-stats{
  display:flex;gap:0;margin-top:70px;
  border-top:1px solid rgba(255,255,255,0.1);
  padding-top:40px;
  opacity:0;animation:fadeUp 0.7s ease 1s forwards;
}
.hero-stat{
  flex:1;padding-right:32px;border-right:1px solid rgba(255,255,255,0.1);margin-right:32px;
}
.hero-stat:last-child{border:none;margin:0;}
.hero-stat-num{font-family:var(--font-display);font-size:2.8rem;font-weight:800;color:var(--sky);line-height:1;}
.hero-stat-label{font-size:0.78rem;color:rgba(255,255,255,0.45);letter-spacing:0.1em;text-transform:uppercase;font-family:var(--font-display);margin-top:4px;}
.hero-scroll{
  position:absolute;bottom:36px;right:64px;
  writing-mode:vertical-rl;
  font-family:var(--font-display);font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;
  color:rgba(255,255,255,0.3);display:flex;align-items:center;gap:12px;
  opacity:0;animation:fadeIn 1s ease 1.3s forwards;
}
.hero-scroll::after{content:'';width:1px;height:44px;background:linear-gradient(to bottom,var(--sky),transparent);}

/* ── SERVICES STRIP ── */
.services-strip{background:var(--sky);padding:0;}
.services-strip-inner{
  max-width:var(--max-w);margin:0 auto;padding:0 64px;
  display:flex;gap:0;
}
.strip-item{
  flex:1;padding:28px 0;border-right:1px solid rgba(255,255,255,0.25);
  display:flex;align-items:center;gap:12px;padding-left:0;padding-right:24px;margin-right:24px;
}
.strip-item:last-child{border:none;margin:0;}
.strip-item svg{flex-shrink:0;color:rgba(255,255,255,0.8);}
.strip-item-text{font-family:var(--font-display);font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--white);}

/* ── ABOUT HOME ── */
.about-home{background:var(--grey-1);border-top:4px solid var(--sky-pale);}
.about-home-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.about-home-text p{font-size:0.97rem;color:var(--text-2);line-height:1.82;margin-bottom:18px;}
.about-visual{
  background:var(--navy);
  padding:52px;
  position:relative;overflow:hidden;
}
.about-visual::before{
  content:'';position:absolute;top:0;left:0;right:0;height:4px;
  background:linear-gradient(90deg,var(--sky),var(--sky-light),var(--sky));
}
.stat-blocks{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(41,171,226,0.15);}
.stat-block{background:var(--navy-2);padding:28px 24px;text-align:center;}
.stat-block-num{font-family:var(--font-display);font-size:2.6rem;font-weight:800;color:var(--sky);line-height:1;}
.stat-block-label{font-family:var(--font-display);font-size:0.62rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-top:5px;}

/* ── SERVICES CARDS ── */
.services-bg{background:var(--white);}
.services-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--grey-2);border:1px solid var(--grey-2);margin-top:52px;}
.service-card{background:var(--white);padding:44px 36px;transition:all 0.3s;position:relative;overflow:hidden;}
.service-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:3px;
  background:var(--sky);transform:scaleX(0);transition:transform 0.3s;transform-origin:left;
}
.service-card:hover{background:var(--sky-ultra);}
.service-card:hover::after{transform:scaleX(1);}
.service-icon{
  width:52px;height:52px;background:var(--sky-pale);
  display:flex;align-items:center;justify-content:center;
  color:var(--sky-dark);margin-bottom:22px;border-radius:var(--radius);
}
.service-title{font-family:var(--font-display);font-size:1.25rem;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;color:var(--navy);margin-bottom:10px;}
.service-desc{font-size:0.88rem;color:var(--text-2);line-height:1.75;}
.service-link{font-family:var(--font-display);font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--sky);margin-top:18px;display:inline-flex;align-items:center;gap:6px;text-decoration:none;cursor:pointer;transition:gap 0.2s;}
.service-link:hover{gap:10px;}

/* ── BLUE CTA BAND ── */
.cta-band{
  background:linear-gradient(135deg,var(--navy) 0%,var(--navy-2) 50%,#0d2645 100%);
  position:relative;overflow:hidden;
}
.cta-band::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 80% at 80% 50%,rgba(41,171,226,0.15) 0%,transparent 65%);
}
.cta-band-inner{
  position:relative;z-index:1;
  max-width:var(--max-w);margin:0 auto;padding:80px 64px;
  display:flex;align-items:center;justify-content:space-between;gap:40px;flex-wrap:wrap;
}
.cta-band-title{font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);font-weight:800;text-transform:uppercase;letter-spacing:0.02em;color:var(--white);line-height:1.05;}
.cta-band-title span{color:var(--sky-light);}
.cta-band-sub{font-size:0.9rem;color:rgba(255,255,255,0.55);max-width:380px;line-height:1.7;margin-top:10px;}
.cta-band-actions{display:flex;gap:12px;flex-wrap:wrap;flex-shrink:0;}

/* ── EDUCATION ── */
.edu-hero{
  background:var(--navy);
  padding:calc(var(--nav-h) + 70px) 64px 60px;
}
.edu-hero-inner{max-width:var(--max-w);margin:0 auto;}
.edu-hero-title{font-family:var(--font-display);font-size:clamp(3rem,6vw,5.5rem);font-weight:800;text-transform:uppercase;line-height:0.95;color:var(--white);margin-bottom:18px;}
.edu-hero-title span{color:var(--sky);}
.edu-hero-sub{font-size:0.97rem;color:rgba(255,255,255,0.55);max-width:550px;line-height:1.75;}
.edu-tabs{
  background:var(--white);
  border-bottom:2px solid var(--grey-2);
  position:sticky;top:var(--nav-h);z-index:100;
}
.edu-tabs-inner{max-width:var(--max-w);margin:0 auto;padding:0 64px;display:flex;gap:0;overflow-x:auto;scrollbar-width:none;}
.edu-tabs-inner::-webkit-scrollbar{display:none;}
.edu-tab{
  font-family:var(--font-display);font-size:0.8rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;
  color:var(--grey-4);padding:18px 26px;border:none;background:none;cursor:pointer;
  border-bottom:3px solid transparent;margin-bottom:-2px;
  transition:all 0.25s;white-space:nowrap;
}
.edu-tab:hover{color:var(--navy);}
.edu-tab.active{color:var(--sky-dark);border-bottom-color:var(--sky);}

/* EDU CONTENT */
.edu-section{display:none;}
.edu-section.active{display:block;}

/* Process cards */
.process-intro{max-width:var(--max-w);margin:0 auto;padding:64px 64px 20px;}
.process-intro p{font-size:0.97rem;color:var(--text-2);line-height:1.8;max-width:680px;}
.process-steps{max-width:var(--max-w);margin:0 auto;padding:0 64px 80px;}
.process-step{
  display:grid;grid-template-columns:80px 1fr;gap:32px;
  padding:40px 0;border-bottom:1px solid var(--grey-2);
  align-items:start;
}
.process-step:last-child{border:none;}
.process-step-num{
  font-family:var(--font-display);font-size:3.5rem;font-weight:800;
  color:var(--sky-pale);line-height:1;text-align:center;
  position:relative;
}
.process-step-num::after{
  content:'';position:absolute;bottom:-8px;left:50%;transform:translateX(-50%);
  width:2px;height:28px;background:var(--grey-2);
}
.process-step:last-child .process-step-num::after{display:none;}
.process-step-content h3{font-family:var(--font-display);font-size:1.5rem;font-weight:800;text-transform:uppercase;letter-spacing:0.04em;color:var(--navy);margin-bottom:10px;}
.process-step-content .step-tag{font-family:var(--font-display);font-size:0.65rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--sky);margin-bottom:8px;}
.process-step-content p{font-size:0.9rem;color:var(--text-2);line-height:1.8;margin-bottom:14px;}
.step-facts{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;}
.step-fact{background:var(--sky-ultra);border:1px solid var(--sky-pale);padding:5px 14px;font-family:var(--font-display);font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--sky-dark);border-radius:var(--radius);}

/* Products grid */
.products-grid{max-width:var(--max-w);margin:0 auto;padding:48px 64px 80px;display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.product-card{
  background:var(--white);border:1px solid var(--grey-2);
  padding:0;overflow:hidden;
  transition:box-shadow 0.3s,transform 0.3s;
  border-radius:var(--radius);
}
.product-card:hover{box-shadow:0 12px 40px rgba(41,171,226,0.14);transform:translateY(-3px);}
.product-card-header{background:var(--navy);padding:32px 28px 24px;position:relative;overflow:hidden;}
.product-card-header::before{content:'';position:absolute;bottom:-20px;right:-20px;width:80px;height:80px;border-radius:50%;background:rgba(41,171,226,0.12);}
.product-icon{color:var(--sky-light);margin-bottom:12px;}
.product-name{font-family:var(--font-display);font-size:1.15rem;font-weight:800;text-transform:uppercase;letter-spacing:0.04em;color:var(--white);}
.product-type{font-family:var(--font-display);font-size:0.62rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--sky-light);margin-top:4px;opacity:0.7;}
.product-card-body{padding:24px 28px;}
.product-desc{font-size:0.86rem;color:var(--text-2);line-height:1.75;margin-bottom:16px;}
.product-specs{list-style:none;display:flex;flex-direction:column;gap:6px;}
.product-specs li{font-size:0.8rem;color:var(--text-2);display:flex;gap:8px;align-items:flex-start;}
.product-specs li::before{content:'✓';color:var(--sky);font-weight:700;flex-shrink:0;}

/* Glossary */
.glossary-grid{max-width:var(--max-w);margin:0 auto;padding:48px 64px 80px;display:grid;grid-template-columns:1fr 1fr;gap:20px;}
.glossary-item{
  background:var(--grey-1);border:1px solid var(--grey-2);
  padding:24px 26px;border-radius:var(--radius);
  border-left:4px solid var(--sky);
  transition:background 0.2s;
}
.glossary-item:hover{background:var(--sky-ultra);}
.glossary-term{font-family:var(--font-display);font-size:1.05rem;font-weight:800;text-transform:uppercase;letter-spacing:0.04em;color:var(--navy);margin-bottom:8px;}
.glossary-def{font-size:0.85rem;color:var(--text-2);line-height:1.72;}

/* Water Quality */
.quality-section{max-width:var(--max-w);margin:0 auto;padding:48px 64px 80px;}
.quality-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:28px;margin-top:32px;}
.quality-card{
  background:var(--white);border:1px solid var(--grey-2);padding:32px;
  border-radius:var(--radius);position:relative;overflow:hidden;
}
.quality-card::before{content:'';position:absolute;top:0;left:0;bottom:0;width:4px;background:var(--sky);}
.quality-card-title{font-family:var(--font-display);font-size:1.15rem;font-weight:800;text-transform:uppercase;letter-spacing:0.04em;color:var(--navy);margin-bottom:10px;}
.quality-card p{font-size:0.87rem;color:var(--text-2);line-height:1.78;}
.quality-table{width:100%;border-collapse:collapse;margin-top:36px;}
.quality-table th{background:var(--navy);color:var(--white);font-family:var(--font-display);font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;padding:12px 16px;text-align:left;}
.quality-table td{padding:11px 16px;font-size:0.84rem;color:var(--text-2);border-bottom:1px solid var(--grey-2);}
.quality-table tr:hover td{background:var(--sky-ultra);}
.badge-safe{background:#D1FAE5;color:#065F46;font-family:var(--font-display);font-size:0.62rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:20px;}
.badge-warn{background:#FEF3C7;color:#92400E;font-family:var(--font-display);font-size:0.62rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 10px;border-radius:20px;}

/* ── ABOUT PAGE ── */
.about-hero-section{
  background:var(--navy);
  padding:calc(var(--nav-h) + 80px) 64px 80px;
}
.about-hero-inner{max-width:var(--max-w);margin:0 auto;}
