<script>
const AV_SYSTEM_PROMPT = `You are the Avalanche Engineering AI Assistant — a knowledgeable, professional, and helpful assistant for Avalanche Engineering, a full-service water treatment and engineering company based in Nigeria.

ABOUT AVALANCHE ENGINEERING:
- 18+ years of experience in water treatment engineering
- ISO 9001:2015 certified, COREN registered, WHO and SON standards compliant
- 42 certified engineers, 500+ projects delivered, 99.8% compliance rate
- Based in Lagos, Nigeria — serving municipal, industrial, and residential sectors
- Services: Municipal water treatment, industrial wastewater, residential systems, UV/disinfection, reverse osmosis, filtration & softening, maintenance & support
- Contact: info@avalancheengineering.com | +234 (0) 801 234 5678

PRODUCTS WE SUPPLY AND INSTALL:
- Multimedia filters (0.5–500 m³/hr flow rates)
- Water softeners (ion exchange, duplex systems available)
- UV disinfection units (NSF/ANSI 55 Class A certified)
- Reverse osmosis systems (domestic to industrial scale)
- Chemical dosing systems (coagulants, disinfectants, pH correction)
- Activated carbon filters (GAC, for chlorine/taste/odour removal)

WATER TREATMENT KNOWLEDGE YOU HAVE:
- Full understanding of treatment stages: coagulation, flocculation, sedimentation, filtration, disinfection, pH correction, reverse osmosis
- Water quality parameters: turbidity, pH, TDS, hardness, nitrates, heavy metals, E.coli, coliforms, residual chlorine
- WHO and SON (Standard Organisation of Nigeria) drinking water guidelines
- Technologies: sand filtration, membrane filtration, UV, ozone, chlorination, ion exchange, RO

YOUR ROLE:
- Answer questions clearly about water treatment processes, products, water quality, and standards
- Help customers understand what type of system they might need based on their situation
- For specific project sizing or technical recommendations, encourage them to contact our engineers directly
- Be warm, professional, and authoritative — the voice of a trusted engineering company
- When users describe a project or express interest in getting a system, naturally offer to connect them with the team
- Keep answers concise but technically accurate — 2–5 sentences for most questions
- Never make up specifications or certifications not listed above
- If unsure about a specific detail, say: "For precise specifications on that, our engineering team can advise — feel free to reach out via our Contact page or I can take your details."`;

let avChatOpen = false;
let avChatHistory = [];
let avMsgCount = 0;
let avLeadShown = false;

function avToggleChat(){
  avChatOpen = !avChatOpen;
  document.getElementById('avChatWindow').classList.toggle('open', avChatOpen);
  document.getElementById('avChatOpen').style.display = avChatOpen ? 'none' : 'block';
  document.getElementById('avChatClose').style.display = avChatOpen ? 'block' : 'none';
  if(avChatOpen) document.getElementById('avChatInput').focus();
}

function avSendQuick(text){
  const qb = document.getElementById('avQuickBtns');
  if(qb) qb.remove();
  avAddUser(text);
  avGetResponse(text);
}

function avSendMessage(){
  const inp = document.getElementById('avChatInput');
  const text = inp.value.trim();
  if(!text) return;
  inp.value = '';
  avAddUser(text);
  avGetResponse(text);
}

function avAddUser(text){
  avChatHistory.push({role:'user', content:text});
  const msgs = document.getElementById('avChatMessages');
  const d = document.createElement('div');
  d.className = 'av-chat-msg user';
  d.innerHTML = `<div class="av-bubble-msg">${avEsc(text)}</div>`;
  msgs.appendChild(d);
  msgs.scrollTop = msgs.scrollHeight;
  avMsgCount++;
}

function avAddBot(text){
  avChatHistory.push({role:'assistant', content:text});
  const msgs = document.getElementById('avChatMessages');
  const d = document.createElement('div');
  d.className = 'av-chat-msg bot';
  d.innerHTML = `<div class="av-bubble-msg">${text}</div>`;
  msgs.appendChild(d);
  msgs.scrollTop = msgs.scrollHeight;
  if(!avLeadShown && avMsgCount >= 2){
    avLeadShown = true;
    setTimeout(avShowLead, 1000);
  }
}

function avShowTyping(){
  const msgs = document.getElementById('avChatMessages');
  const d = document.createElement('div');
  d.className = 'av-chat-msg bot'; d.id = 'avTyping';
  d.innerHTML = `<div class="av-typing"><span></span><span></span><span></span></div>`;
  msgs.appendChild(d); msgs.scrollTop = msgs.scrollHeight;
}

function avRemoveTyping(){ const t=document.getElementById('avTyping'); if(t)t.remove(); }

function avShowLead(){
  document.getElementById('avLeadCapture').style.display = 'block';
  document.getElementById('avChatInputRow').style.display = 'none';
}

function avDismissLead(){
  document.getElementById('avLeadCapture').style.display = 'none';
  document.getElementById('avChatInputRow').style.display = 'flex';
  document.getElementById('avChatInput').focus();
}

function avSubmitLead(){
  const name = document.getElementById('avLeadName').value.trim();
  const email = document.getElementById('avLeadEmail').value.trim();
  if(!name){ document.getElementById('avLeadName').focus(); return; }
  if(!email || !email.includes('@')){ document.getElementById('avLeadEmail').focus(); return; }
  document.getElementById('avLeadCapture').style.display = 'none';
  document.getElementById('avChatInputRow').style.display = 'flex';
  avAddBot(`Thank you, ${avEsc(name)}! One of our engineers will be in touch at <strong>${avEsc(email)}</strong> shortly. Is there anything else I can help you with in the meantime?`);
  notify("Enquiry received. Our team will be in touch.");
}

async function avGetResponse(userText){
  document.getElementById('avChatInput').disabled = true;
  avShowTyping();
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system: AV_SYSTEM_PROMPT,
        messages: avChatHistory.slice(0,-1).concat([{role:'user',content:userText}])
      })
    });
    const data = await res.json();
    avRemoveTyping();
    if(data.content && data.content[0] && data.content[0].text){
      avAddBot(data.content[0].text);
    } else {
      avAddBot("I'm having a connection issue. Please try again or contact us directly at info@avalancheengineering.com.");
    }
  } catch(e){
    avRemoveTyping();
    avAddBot("Connection issue — please try again or contact our team directly at <strong>info@avalancheengineering.com</strong> or call <strong>+234 (0) 801 234 5678</strong>.");
  }
  document.getElementById('avChatInput').disabled = false;
  document.getElementById('avChatInput').focus();
}

function avEsc(t){ return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
</script>

