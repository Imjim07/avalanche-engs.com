// NAV
function navigate(page){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  const t=document.getElementById('page-'+page);
  if(t){t.classList.add('active','page-in');setTimeout(()=>t.classList.remove('page-in'),400);}
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.toggle('active',a.dataset.page===page));
  window.scrollTo({top:0,behavior:'instant'});
  if(page==='home')setTimeout(initCanvas,50);
}
function openMobileNav(){document.getElementById('mobileNav').classList.add('open');}
function closeMobileNav(){document.getElementById('mobileNav').classList.remove('open');}

window.addEventListener('scroll',()=>{
  document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>40);
});

// EDUCATION TABS
function switchEduTab(tab,btn){
  navigate('education');
  document.querySelectorAll('.edu-section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.edu-tab').forEach(t=>t.classList.remove('active'));
  const s=document.getElementById('edu-'+tab);
  if(s)s.classList.add('active');
  if(btn)btn.classList.add('active');
  else{
    document.querySelectorAll('.edu-tab').forEach(t=>{
      if(t.getAttribute('onclick')&&t.getAttribute('onclick').includes("'"+tab+"'"))t.classList.add('active');
    });
  }
  setTimeout(()=>window.scrollTo({top:document.querySelector('.edu-tabs').offsetTop-76,behavior:'smooth'}),100);
}

// HERO CANVAS
function initCanvas(){
  const c=document.getElementById('hero-canvas');
  if(!c)return;
  const ctx=c.getContext('2d');
  c.width=window.innerWidth;c.height=window.innerHeight;
  const pts=Array.from({length:70},()=>({
    x:Math.random()*c.width,y:Math.random()*c.height,
    r:Math.random()*1.8+0.4,
    dx:(Math.random()-0.5)*0.22,dy:(Math.random()-0.5)*0.22,
    a:Math.random()*0.5+0.1
  }));
  function draw(){
    ctx.clearRect(0,0,c.width,c.height);
    pts.forEach(p=>{
      p.x=(p.x+p.dx+c.width)%c.width;
      p.y=(p.y+p.dy+c.height)%c.height;
      ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle=`rgba(41,171,226,${p.a})`;ctx.fill();
    });
    for(let i=0;i<pts.length;i++)for(let j=i+1;j<pts.length;j++){
      const dx=pts[i].x-pts[j].x,dy=pts[i].y-pts[j].y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<120){ctx.beginPath();ctx.moveTo(pts[i].x,pts[i].y);ctx.lineTo(pts[j].x,pts[j].y);
      ctx.strokeStyle=`rgba(41,171,226,${0.07*(1-d/120)})`;ctx.lineWidth=0.6;ctx.stroke();}
    }
    requestAnimationFrame(draw);
  }
  draw();
  window.addEventListener('resize',()=>{c.width=window.innerWidth;c.height=window.innerHeight;});
}
initCanvas();

// NOTIFICATION
function notify(msg){
  const el=document.getElementById('notification');
  el.textContent=msg;el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),3500);
}

// CONTACT FORM
function submitAvContact(){
  const fname=document.getElementById('av-fname').value.trim();
  const email=document.getElementById('av-email').value.trim();
  const msg=document.getElementById('av-message').value.trim();
  if(!fname){notify('Please enter your first name.');return;}
  if(!email||!email.includes('@')){notify('Please enter a valid email.');return;}
  if(!msg){notify('Please describe your project.');return;}
  document.getElementById('av-form').style.display='none';
  document.getElementById('av-success').style.display='block';
  notify('Enquiry submitted. We\'ll be in touch soon.');
}
</script>

